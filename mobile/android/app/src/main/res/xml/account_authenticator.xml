<?xml version="1.0" encoding="utf-8"?>
<!--
    Account type definition for the Pimote-owned Cloudflare-style "Account"
    that owns synced contacts. Visible in Settings → Accounts as "Pimote".
    The accountType MUST match @string/account_type and is the contract used
    by ContactsContract.RawContacts.ACCOUNT_TYPE.
-->
<account-authenticator xmlns:android="http://schemas.android.com/apk/res/android"
    android:accountType="com.pimote.android.account"
    android:icon="@drawable/ic_call_outlined"
    android:smallIcon="@drawable/ic_call_outlined"
    android:label="@string/account_name" />
