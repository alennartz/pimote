<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!--
        Required by ContactSyncRunner.ensureAccount() to call
        ContentResolver.setIsSyncable / setSyncAutomatically when first
        creating the Pimote AccountManager Account. Normal permission —
        granted at install, no runtime prompt.
    -->
    <uses-permission android:name="android.permission.WRITE_SYNC_SETTINGS" />

    <!--
        ContactSyncRunner reads and writes ContactsContract rows owned by the
        Pimote AccountManager Account. CALLER_IS_SYNCADAPTER=true on the URIs
        only relaxes permission checks when the caller is bound as a real
        SyncAdapter (system holds the binder identity). When called from the
        Application process directly — which is what we do, because contacts
        change live with WS events and the sync framework is too async — the
        system still requires READ_CONTACTS / WRITE_CONTACTS at the caller's
        UID. Both are runtime ("dangerous") permissions; MainActivity prompts.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <application
        android:name=".app.PimoteApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".app.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.call.InCallActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <service
            android:name="com.pimote.android.telephony.PimoteConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <!--
            AccountAuthenticator service. Bound by the system AccountManager.
            The authenticator itself is a stub — Pimote doesn't authenticate
            users; auth is handled at the network layer (DR-017). The Account
            exists solely so ContactsContract can group Pimote-synced contacts
            under a "Pimote" Account, which is what gives us unlimited synced
            contacts (vs Telecom's 10-PhoneAccount cap; see DR-019).
        -->
        <service
            android:name="com.pimote.android.accounts.PimoteAuthenticatorService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCOUNT_AUTHENTICATOR">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/account_authenticator" />
            <!--
                Tells the platform that contacts owned by the Pimote Account
                expose a custom callable data kind (vnd.com.pimote.android.call).
                Without this, the system contact card has no per-MIME action to
                render and Assistant / Gemini don't recognize Pimote contacts as
                callable. See DR-019 supersession.
            -->
            <meta-data
                android:name="android.provider.CONTACTS_STRUCTURE"
                android:resource="@xml/contacts" />
        </service>

        <!--
            Contacts SyncAdapter shim. The adapter's onPerformSync is a no-op;
            ContactSyncRunner drives reconciliation directly off SessionRepository.
            Service exists purely so the platform recognizes the Pimote Account as
            a first-class contacts-syncing source (gates visibility in some
            pickers and surfaces the account under Settings → Accounts → Pimote
            → Contacts).
        -->
        <service
            android:name="com.pimote.android.contacts.PimoteSyncAdapterService"
            android:exported="false">
            <intent-filter>
                <action android:name="android.content.SyncAdapter" />
            </intent-filter>
            <meta-data
                android:name="android.content.SyncAdapter"
                android:resource="@xml/syncadapter" />
        </service>
    </application>
</manifest>
